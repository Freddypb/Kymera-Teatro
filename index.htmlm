<div id="toast">¡Copiado!</div>

<script>
  var qPrev = 0, qGen = 0;
  var fechaSel = 'Sábado 4 de julio';

  function selFecha(btn) {
    document.querySelectorAll('.fecha-btn').forEach(function(b){ b.classList.remove('activo'); });
    btn.classList.add('activo');
    fechaSel = btn.dataset.fecha;
  }

  function cambiar(tipo, delta) {
    if (tipo === 'prev') {
      qPrev = Math.max(0, qPrev + delta);
      document.getElementById('q-prev').textContent = qPrev;
    } else {
      qGen = Math.max(0, qGen + delta);
      document.getElementById('q-gen').textContent = qGen;
    }
    var total = qPrev * 250 + qGen * 320;
    document.getElementById('total-display').textContent = '$' + total.toLocaleString('es-MX') + ' MXN';
  }

  function abrirWA(e) {
    e.preventDefault();
    if (qPrev === 0 && qGen === 0) {
      mostrarToast('Elige al menos un boleto');
      return;
    }
    var partes = [];
    if (qPrev > 0) partes.push(qPrev + ' boleto' + (qPrev > 1 ? 's' : '') + ' preventa ($250)');
    if (qGen > 0) partes.push(qGen + ' boleto' + (qGen > 1 ? 's' : '') + ' general ($320)');
    var total = qPrev * 250 + qGen * 320;
    var msg = '¡Hola! Quiero apartar boletos para KYNARIO 2026.\n\n'
      + '📅 Fecha: ' + fechaSel + ', 7:00 PM\n'
      + '🎭 Sede: Punto Escénico, Guadalajara\n'
      + '🎟️ ' + partes.join(' + ') + '\n'
      + '💳 Total: $' + total.toLocaleString('es-MX') + ' MXN\n\n'
      + 'Ya realicé la transferencia SPEI. Adjunto comprobante.';
    window.open('https://wa.me/523318300226?text=' + encodeURIComponent(msg), '_blank');
  }

  function copiar(texto, el) {
    navigator.clipboard.writeText(texto).then(function() {
      mostrarToast('Copiado: ' + texto);
    }).catch(function() {
      mostrarToast('Copiado');
    });
  }

  function mostrarToast(msg) {
    var t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.add('visible');
    setTimeout(function(){ t.classList.remove('visible'); }, 2200);
  }
</script>
</body>
</html>
